{
    "name": "@santh/agent",
    "version": "1.0.0",
    "private": false,
    "description": "INVARIANT backend defense agent. RASP, dependency scanning, config auditing. Zero-code protection.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./auto": {
            "import": "./dist/auto.js"
        },
        "./middleware/express": {
            "types": "./dist/middleware/express.d.ts",
            "import": "./dist/middleware/express.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "dependencies": {
        "better-sqlite3": "^11.0.0"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.0",
        "typescript": "^5.7.0",
        "vitest": "^4.0.0"
    },
    "keywords": [
        "security",
        "rasp",
        "agent",
        "defense",
        "invariant"
    ],
    "license": "MIT"
}