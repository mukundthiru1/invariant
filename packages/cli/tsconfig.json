{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "lib": [
            "ES2022"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": false,
        "sourceMap": true,
        "types": ["node"],
        "outDir": "./dist",
        "rootDir": "../../packages"
    },
    "include": [
        "src/**/*",
        "../engine/src/**/*",
        "../agent/src/**/*",
        "../dashboard/src/**/*"
    ]
}