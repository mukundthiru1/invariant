{
    "name": "@santh/auth-gate",
    "version": "1.0.0",
    "private": true,
    "description": "Santh deployment approval gate using WebAuthn passkeys.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "dependencies": {
        "@simplewebauthn/server": "^10.0.0",
        "web-push": "^3.6.7"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20250224.0",
        "typescript": "^5.7.0",
        "vitest": "^4.0.0",
        "wrangler": "^4.69.0"
    }
}
