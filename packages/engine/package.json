{
    "name": "@santh/invariant-engine",
    "version": "1.0.0",
    "private": false,
    "description": "INVARIANT detection engine. Matches invariant PROPERTIES, not signatures. Zero dependencies.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "devDependencies": {
        "typescript": "^5.7.0",
        "vitest": "^4.0.0"
    },
    "keywords": [
        "security",
        "invariant",
        "detection",
        "defense",
        "waf",
        "rasp"
    ],
    "license": "MIT"
}