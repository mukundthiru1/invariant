{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["@cloudflare/workers-types", "node", "vitest/globals"],
    "outDir": "./dist",
    "rootDir": "../.."
  },
  "include": ["src/**/*"],
  "exclude": ["tests/**/*"]
}
